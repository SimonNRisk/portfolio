# .env.local
GITHUB_TOKEN=ghp_xxx_your_token_here
GITHUB_LOGIN=your-github-username
GITHUB_TZ=America/Toronto   # or any IANA TZ you want the "day" to be in

# Public email is only returned from POST /api/contact when token matches.
CONTACT_EMAIL=your-email@example.com
CONTACT_REVEAL_TOKEN=use-a-long-random-string
# Same value as CONTACT_REVEAL_TOKEN (required for the browser to send after captcha).
NEXT_PUBLIC_CONTACT_REVEAL_TOKEN=use-a-long-random-string